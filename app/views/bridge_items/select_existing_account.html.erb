<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: "Link Bridge account") %>

    <% dialog.with_body do %>
      <%= form_with url: link_existing_account_bridge_items_path, method: :post, class: "space-y-4" do %>
        <%= hidden_field_tag :account_id, @account.id %>

        <div class="space-y-2 max-h-64 overflow-auto">
          <% @available_bridge_accounts.each do |bridge_account| %>
            <label class="flex items-center gap-3 p-2 rounded border border-surface-inset/50 hover:border-primary cursor-pointer">
              <%= radio_button_tag :bridge_account_id, bridge_account.id, false %>
              <div class="flex flex-col">
                <span class="text-sm text-primary font-medium"><%= bridge_account.name %></span>
                <span class="text-xs text-secondary">
                  <%= bridge_account.currency %> • Balance: <%= number_to_currency((bridge_account.current_balance || 0), unit: bridge_account.currency) %>
                </span>
              </div>
            </label>
          <% end %>
        </div>

        <div class="flex items-center justify-end gap-2">
          <%= render DS::Button.new(text: "Link", variant: :primary, icon: "link-2", type: :submit) %>
          <%= render DS::Link.new(text: "Cancel", variant: :secondary, href: accounts_path, data: { turbo_frame: "_top" }) %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>
